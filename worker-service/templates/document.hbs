<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Helvetica', sans-serif; margin: 40px; color: #333; }
        .header { text-align: center; border-bottom: 2px solid #004a99; padding-bottom: 10px; }
        .content { margin-top: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f2f2f2; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 10px; color: #777; }
    </style>
</head>
<body>
    <div class="header">
        <h1>DocEngine-X: {{template_type}}</h1>
    </div>
    <div class="content">
        <p><strong>ID de Documento:</strong> {{id}}</p>
        <p><strong>Fecha de Generación:</strong> {{date}}</p>
        <hr>
        {{{custom_html}}} </div>
    <div class="footer">Documento generado automáticamente por DocEngine-X Service</div>
</body>
</html>